# ─────────────────────────────────────────────────────────────────────────────
# DevHash website — environment variables
# Copy to `.env.local` for local development and configure in your host for prod.
# ─────────────────────────────────────────────────────────────────────────────

# Canonical production origin (no trailing slash). Used for canonical URLs,
# hreflang, sitemap, robots and Open Graph absolute URLs.
NEXT_PUBLIC_SITE_URL="https://www.example.com"

# Gate for unconfirmed business facts. Until set to "true", any value flagged as
# unconfirmed in src/config is hidden from the rendered site (see PRE_LAUNCH_CHECKLIST).
# Do NOT set to "true" until every placeholder in the checklist is real & approved.
NEXT_PUBLIC_LAUNCH_READY="false"

# ── Contact form delivery (server-only) ─────────────────────────────────────
# The enquiry form works without these (it logs in dev and returns success),
# but production delivery requires a provider. Resend is wired by default.
RESEND_API_KEY=""
CONTACT_INBOX="hello@example.com"
CONTACT_FROM="DevHash Website <noreply@example.com>"

# Optional anti-spam: simple shared secret appended by client + checked server-side.
# Leave empty to disable. (The form also uses a honeypot + timing check.)
CONTACT_FORM_SECRET=""
